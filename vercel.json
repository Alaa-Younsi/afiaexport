{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/contact.js": {
      "includeFiles": "node_modules/nodemailer/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
